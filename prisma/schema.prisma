generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  // شماره کلید اصلی هویت است ولی ممکن است در ثبت‌نام از تلگرام/بله موقتاً null باشد
  // و در lead capture (بعد از روز اول) گرفته شود.
  phone           String?   @unique
  telegramId      String?   @unique // شناسه تلگرام (لینک‌شده به همین حساب)
  baleId          String?   @unique // شناسه بله
  name            String?
  grade           String?
  field           String?
  avatarUrl       String?
  xp              Int       @default(0)
  coins           Int       @default(0)
  level           String    @default("تازه‌نفس")
  stars           Int       @default(1)
  onboardingDay        Int       @default(0)
  onboardingStepMinutes Int      @default(0) // دقایق مطالعه انباشته‌شده برای روز جاری آنبوردینگ
  nextStudyTarget      DateTime?
  isLeadComplete       Boolean   @default(false)
  hasSeenIntro         Boolean   @default(false)
  pastAvgStudyHours    Float?
  day1GoalMinutes      Int?      // هدف روز اول؛ هنگام پاسخ به پرسش میانگین snapshot می‌شود (قانون ساعت ۱۷/۲۱)
  streak               Int       @default(0)  // زنجیره روزهای متوالی مطالعه
  lastStudyDate        DateTime? // آخرین روزی (00:00) که جلسه‌ای ثبت شده — مبنای streak
  referralCode         String?   @unique // کد دعوت دوستان
  role                 String    @default("user") // user | admin
  // A/B تست مدل دسترسی به ویدیو: "free" (باز با پیشرفت روز) یا "paid" (خرید با سکه).
  // null = هنوز تخصیص نیافته؛ در اولین ورود به اپ مقداردهی می‌شود.
  videoAccess          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions     StudySession[]
  userMissions UserMission[]
  userMedals   UserMedal[]
  activityLogs ActivityLog[]
  videoProg    VideoProgress[]
  unlocksMade     ProfileUnlock[] @relation("UnlocksMade")
  unlocksReceived ProfileUnlock[] @relation("UnlocksReceived")
  friendsInitiated Friendship[] @relation("FriendshipsInitiated")
  friendsReceived  Friendship[] @relation("FriendshipsReceived")
  pushSubscriptions PushSubscription[]
  tournamentEntries TournamentParticipant[]
  reactionsMade     Reaction[]  @relation("ReactionsMade")
  reactionsReceived Reaction[]  @relation("ReactionsReceived")
  inboxItems        InboxItem[] @relation("InboxRecipient")
  inboxActed        InboxItem[] @relation("InboxActor")
  avatarImage       AvatarImage?
  // آخرین رتبه هفتگی شناخته‌شده (برای نوتیف «فلانی ازت جلو زد»)
  lastWeeklyRank   Int?

  @@index([xp])
  @@index([level])
}

// عکس پروفایل آپلودیِ کاربر — به‌صورت bytes داخل دیتابیس نگه داشته می‌شود
// (پروداکشن VPS بدون object storage/volume پایدار است؛ ذخیره در DB با dump/restore
//  هنگام مهاجرت سرور خودکار همراه می‌آید). تصویر در کلاینت به مربعِ کوچک فشرده می‌شود.
// در جدول جدا نگه داشته شده تا کوئری‌های سنگینِ User (فید/لیدربورد) بایت‌ها را لود نکنند.
model AvatarImage {
  userId      String   @id
  data        Bytes
  contentType String
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// باز کردن مشاهده لاگ مطالعه یک کاربر دیگر با پرداخت سکه (تا ۱ روز)
model ProfileUnlock {
  id           String   @id @default(cuid())
  viewerId     String
  targetUserId String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  viewer User @relation("UnlocksMade", fields: [viewerId], references: [id], onDelete: Cascade)
  target User @relation("UnlocksReceived", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([viewerId, targetUserId])
  @@index([viewerId])
}

model StudySession {
  id          String    @id @default(cuid())
  userId      String
  startTime   DateTime
  endTime     DateTime?
  durationMin Int       @default(0)
  plannedMin  Int       @default(0) // مدت انتخابی تایمر (۳۰/۶۰/۹۰/۱۲۰) — سقف پاداش
  tickCount   Int       @default(0) // تعداد پاداش‌های ۱۵دقیقه‌ای پرداخت‌شده (ضد تقلب)
  pausedSec   Int       @default(0) // مجموع ثانیه‌های pause شده (سمت سرور)
  pausedAt    DateTime? // اگر الان pause است، از کی
  xpEarned    Int       @default(0)
  coinsEarned Int       @default(0)
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startTime])
}

model Mission {
  id          String  @id @default(cuid())
  // نوع ماموریت: "weekly" (هدف ۷روزه، جایزه XP+مدال) یا "daily" (هدف یک‌روزه، جایزه سکه)
  kind        String  @default("weekly")
  targetHours Int
  minAvgHours Float
  entryCost   Int
  xpReward    Int
  coinReward  Int     @default(0) // جایزه سکه (برای ماموریت روزانه)
  medalId     String?
  description String?
  isActive    Boolean @default(true)

  medal        Medal?        @relation(fields: [medalId], references: [id])
  userMissions UserMission[]
}

model UserMission {
  id          String    @id @default(cuid())
  userId      String
  missionId   String
  purchasedAt DateTime  @default(now())
  activatesAt DateTime  // ماموریت از روز بعد فعال می‌شود
  expiresAt   DateTime  // activatesAt + ۷ روز
  completedAt DateTime?
  status      String    @default("pending") // pending | active | completed | failed

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id])

  @@index([userId, status])
}

model Medal {
  id          String  @id @default(cuid())
  name        String
  targetHours Int     @unique
  iconUrl     String?

  missions   Mission[]
  userMedals UserMedal[]
}

model UserMedal {
  id       String   @id @default(cuid())
  userId   String
  medalId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  medal Medal @relation(fields: [medalId], references: [id])

  @@index([userId])
}

model Video {
  id           String   @id @default(cuid())
  title        String
  description  String?
  day          Int      @default(0) // روز آنبوردینگ (۱ به بالا؛ طول مسیر = بیشترین day فعال)
  durationMin  Int
  hlsUrl       String
  thumbnailUrl String?
  grades       String[] @default([]) // پایه‌های هدف؛ خالی = همه پایه‌ها
  ctaLabel     String?  // متن دکمه CTA زیر ویدیو (مثلاً «درخواست مشاوره رایگان»)
  ctaUrl       String?  // لینک دکمه CTA
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  progresses VideoProgress[]

  @@index([day])
}

model VideoProgress {
  id             String   @id @default(cuid())
  userId         String
  videoId        String
  watchedSeconds Int      @default(0)
  totalSeconds   Int      @default(0)
  completed      Boolean  @default(false)
  rewardGiven    Boolean  @default(false)
  unlockedAt     DateTime? // زمان باز شدن ویدیو (مبنای جایزه ۲× تماشای سریع در ۲۴ ساعت)
  purchasedAt    DateTime? // زمان خرید ویدیو با سکه (فقط گروه A/B «paid»)
  updatedAt      DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id])

  @@unique([userId, videoId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  type      String
  metadata  Json?
  createdAt DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions Reaction[]

  @@index([createdAt(sort: Desc)])
  @@index([userId])
}

// واکنش یک کاربر به یک آیتم فید (هر کاربر روی هر آیتم فقط یک واکنش؛ قابل تغییر/برداشتن)
model Reaction {
  id           String   @id @default(cuid())
  actorId      String   // واکنش‌دهنده
  activityId   String   // آیتم فید
  targetUserId String   // صاحب آیتم فید (denormalized برای شمارش جایزه و صندوق)
  emoji        String   // یکی از مجموعه‌ی مجاز (lib/reaction.ts)
  createdAt    DateTime @default(now())

  actor    User        @relation("ReactionsMade", fields: [actorId], references: [id], onDelete: Cascade)
  target   User        @relation("ReactionsReceived", fields: [targetUserId], references: [id], onDelete: Cascade)
  activity ActivityLog @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([actorId, activityId])
  @@index([activityId])
  @@index([actorId, createdAt])
  @@index([targetUserId])
}

// صندوق پیام/نوتیفیکیشن کاربر (واکنش‌های دریافتی، جایزه‌ها؛ آماده‌ی توسعه به DM)
model InboxItem {
  id        String   @id @default(cuid())
  userId    String   // گیرنده
  type      String   // reaction | reaction_reward | system | message
  actorId   String?  // کاربری که باعث این آیتم شد (مثلاً واکنش‌دهنده)
  body      String?  // متن (برای پیام خصوصی آینده)
  metadata  Json?    // داده‌ی نمایشی (emoji، نوع فعالیت، coins، ...)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User  @relation("InboxRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("InboxActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
}

model OtpToken {
  phone     String   @id
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// دوستی دوطرفه (یک رکورد برای هر جفت؛ کوئری با OR روی دو ستون)
model Friendship {
  id        String   @id @default(cuid())
  userId    String   // دعوت‌کننده
  friendId  String   // دعوت‌شده
  createdAt DateTime @default(now())

  user   User @relation("FriendshipsInitiated", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendshipsReceived", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([friendId])
}

// اشتراک Web Push مرورگر (یک کاربر می‌تواند چند دستگاه داشته باشد)
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// تورنومنت‌های ویژه‌ی ادمین: رقابت بازه‌دار با اتاق و لیدربورد جداگانه.
// لیدربورد هفتگی اصلی دست‌نخورده می‌ماند؛ این رقابت موازی است.
model Tournament {
  id          String   @id @default(cuid())
  name        String
  description String?
  startAt     DateTime
  endAt       DateTime
  entryCost   Int      @default(0)  // هزینه ورود (سکه)
  prizeXp     Int      @default(0)  // جایزه XP نفر اول
  prizeCoins  Int      @default(0)  // جایزه سکه نفر اول
  // محدودیت سطح (خالی = همه سطوح می‌توانند شرکت کنند)
  levels      String[] @default([])
  isActive    Boolean  @default(true)
  rewardsPaid Boolean  @default(false) // آیا جوایز پایان تورنومنت پرداخت شده
  createdAt   DateTime @default(now())

  participants TournamentParticipant[]

  @@index([startAt])
  @@index([endAt])
}

model TournamentParticipant {
  id           String   @id @default(cuid())
  tournamentId String
  userId       String
  joinedAt     DateTime @default(now())
  // XP کسب‌شده در بازه‌ی تورنومنت (snapshot هنگام محاسبه؛ منبع: StudySession)
  score        Int      @default(0)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([tournamentId])
}

// قانون نوتیفیکیشن قابل‌تعریف توسط ادمین (موتور قانون).
// هر قانون: تریگر (چه‌وقت) + شرط‌ها (به‌چه‌کسی) + پیام (چه‌چیزی) + ایمنی (cooldown/quiet).
model NotificationRule {
  id            String   @id @default(cuid())
  name          String
  enabled       Boolean  @default(true)
  // کانال‌های ارسال: ["bale","push"]
  channels      String[] @default([])
  // نوع تریگر: scheduled | relative | event
  triggerType   String
  // تنظیمات تریگر (بسته به نوع):
  //   scheduled: { hour, minute, weekdays:[0..6] }
  //   relative:  { beforeTargetMin }
  //   event:     { event: "session_complete"|"streak_milestone"|"level_up"|"medal_earn"|"rank_drop" }
  triggerConfig Json
  // سگمنت آماده (اختیاری؛ میان‌بُر برای پر کردن شرط‌ها). مثلا "inactive" | "newbie" | ...
  segment       String?
  // شرط‌های سفارشی (AND): [{ field, op, value }]
  conditions    Json     @default("[]")
  // متن پیام (با متغیر {{name}} {{streak}} ...)
  title         String
  body          String
  linkUrl       String?
  // ایمنی
  cooldownHours Int      @default(24) // فاصله مجاز تا ارسال دوباره همین قانون به همان کاربر
  quietStart    Int?     // ساعت شروع سکوت (0-23)
  quietEnd      Int?     // ساعت پایان سکوت
  maxPerDay     Int?     // سقف نوتیف این قانون برای هر کاربر در روز
  lastRunAt     DateTime?
  sentCount     Int      @default(0) // شمارنده کل ارسال‌ها (برای گزارش)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  logs NotificationLog[]

  @@index([enabled, triggerType])
}

// لاگ ارسال هر نوتیف (برای cooldown، سقف روزانه و گزارش).
model NotificationLog {
  id        String   @id @default(cuid())
  ruleId    String
  userId    String
  channel   String
  sentAt    DateTime @default(now())

  rule NotificationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, userId, sentAt])
  @@index([userId, sentAt])
}
